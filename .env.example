# ===== Stripe =====
# Live secret key: Stripe Dashboard -> Developers -> API keys
STRIPE_SECRET_KEY=sk_live_...
# Public Payment Link (override of the default in lib/site.ts)
NEXT_PUBLIC_STRIPE_PAYMENT_URL=https://buy.stripe.com/3cI7sK7h75Vz4EYeFxa7C00
# Webhook signing secret: Workbench -> Webhooks -> your endpoint -> Signing secret (Reveal)
STRIPE_WEBHOOK_SECRET=whsec_...

# ===== GitHub (private release -> signed .dmg URL) =====
GHOST_GITHUB_TOKEN=github_pat_...
# Optional overrides:
# GHOST_GITHUB_REPO=knodelchik/ghost-assistant
# GHOST_RELEASE_TAG=v0.5.1

# ===== Firebase Admin (server) =====
# From the service-account JSON: Project settings -> Service accounts -> Generate new private key
FIREBASE_PROJECT_ID=ghost-assistant
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@ghost-assistant.iam.gserviceaccount.com
# Paste the whole private_key value INCLUDING the BEGIN/END lines; keep the \n escapes as-is.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# ===== Firebase Web (public — used by the Electron app via REST sign-in) =====
# Project settings -> General -> Web API Key (appears after you register a Web app)
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
